<ui:FluentWindow x:Class="ExplorerHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:ExplorerHelper.Controls"
        xmlns:vm="clr-namespace:ExplorerHelper.ViewModels"
        Title="Explorer Helper"
        Height="720" Width="1180"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <ui:FluentWindow.Resources>
        <!--
          GridView keeps WPF's old Aero (Windows 7) chrome — a gradient column header and a
          bright gradient row selection that light text can't sit on. WPF-UI doesn't retheme
          those, so we fully retemplate both with flat, Fluent-style visuals.
        -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border x:Name="HdrBd" Background="Transparent" Padding="10,8"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Content="{TemplateBinding Content}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HdrBd" Property="Background"
                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HdrBd" Property="Background"
                                        Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Margin="0,1" CornerRadius="4"
                                Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="1">
                            <GridViewRowPresenter VerticalAlignment="Center" Margin="0,4"
                                Content="{TemplateBinding Content}"
                                Columns="{Binding Path=View.Columns,
                                          RelativeSource={RelativeSource AncestorType={x:Type ListView}}}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar (custom, draggable, with window controls) -->
        <ui:TitleBar Grid.Row="0" Title="Explorer Helper">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Folder24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Toolbar -->
        <DockPanel Grid.Row="1" Margin="12,4,12,10" LastChildFill="True">
            <ToggleButton x:Name="SettingsButton" DockPanel.Dock="Right" Margin="6,0,0,0"
                          ToolTip="Settings">
                <ui:SymbolIcon Symbol="Settings24" />
            </ToggleButton>
            <Popup PlacementTarget="{Binding ElementName=SettingsButton}" Placement="Bottom"
                   StaysOpen="False" AllowsTransparency="True"
                   IsOpen="{Binding IsChecked, ElementName=SettingsButton, Mode=TwoWay}">
                <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,6,0,0"
                        MaxWidth="320">
                    <StackPanel>
                        <TextBlock Text="Explorer integration" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,8" />
                        <ui:Button Content="{Binding ContextMenuButtonText}"
                                   Command="{Binding ToggleContextMenuCommand}"
                                   HorizontalAlignment="Stretch"
                                   ToolTip="Adds or removes Explorer Helper's &quot;Clean this folder&quot; entry in the right-click menu for your user (no admin needed). On Windows 11 it appears under &quot;Show more options.&quot;" />
                        <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,8,0,0"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="Registers the &quot;Clean this folder&quot; right-click entry for folders. Per-user, no admin required; Remove deletes it again." />

                        <Separator Margin="0,12" />

                        <!-- Quick-use buttons (issue #14): manage the presets and the date formats
                             used by the dynamic "today" / "created" buttons. -->
                        <TextBlock Text="Quick rename buttons" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding QuickNameButtons}">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <StackPanel>
                                        <TextBlock Text="No preset buttons yet — add one from the + under the rename box."
                                                   TextWrapping="Wrap" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Visibility="{Binding HasItems, RelativeSource={RelativeSource TemplatedParent},
                                                                Converter={StaticResource InverseBoolToVisibility}}" />
                                        <ItemsPresenter />
                                    </StackPanel>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,4" LastChildFill="True">
                                        <ui:Button DockPanel.Dock="Right" Padding="6,2" Margin="6,0,0,0"
                                                   Icon="{ui:SymbolIcon Delete24}" Click="RemoveQuickButton_Click"
                                                   Tag="{Binding}" ToolTip="Remove this button" />
                                        <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="4" Padding="8,3">
                                            <TextBlock Text="{Binding}" FontSize="13" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Border>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Date formats" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,12,0,4" />
                        <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,0,0,6"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="Standard .NET date/time format (e.g. yyyy-MM-dd, hh:mm tt, MMM d)." />
                        <TextBlock Text="Today's date" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:TextBox FontSize="13" Margin="0,2,0,2"
                                    Text="{Binding TodayDateFormat, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{Binding TodayFormatPreview, StringFormat=Preview: {0}}"
                                   FontSize="11" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        <TextBlock Text="File created date" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:TextBox FontSize="13" Margin="0,2,0,2"
                                    Text="{Binding CreatedDateFormat, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{Binding CreatedFormatPreview, StringFormat=Preview: {0}}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </Border>
            </Popup>
            <ui:Button DockPanel.Dock="Right" Margin="6,0,0,0"
                       Content="Open in Explorer" Icon="{ui:SymbolIcon Open24}"
                       Command="{Binding OpenInExplorerCommand}" />
            <ui:Button DockPanel.Dock="Right" Margin="6,0,0,0"
                       Content="Undo" Icon="{ui:SymbolIcon ArrowUndo24}"
                       Command="{Binding UndoCommand}"
                       ToolTip="Undo the last rename or delete (Ctrl+Z)" />
            <ui:Button DockPanel.Dock="Right" Margin="6,0,0,0"
                       Content="Refresh" Icon="{ui:SymbolIcon ArrowClockwise24}"
                       Command="{Binding RefreshCommand}" />
            <ui:Button DockPanel.Dock="Right" Margin="6,0,0,0" Appearance="Primary"
                       Content="Triage" Icon="{ui:SymbolIcon Stack24}"
                       Click="Triage_Click"
                       ToolTip="Review files one by one — swipe right to keep, left to reject, then commit everything at once" />
            <ToggleButton x:Name="TypesButton" DockPanel.Dock="Right" Margin="6,0,0,0"
                          Content="Types" ToolTip="Show or hide files by type" />
            <Popup PlacementTarget="{Binding ElementName=TypesButton}" Placement="Bottom"
                   StaysOpen="False" AllowsTransparency="True"
                   IsOpen="{Binding IsChecked, ElementName=TypesButton, Mode=TwoWay}">
                <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,6,0,0"
                        MinWidth="220">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:Button Content="All" Command="{Binding ShowAllTypesCommand}" />
                            <ui:Button Content="None" Command="{Binding HideAllTypesCommand}" Margin="6,0,0,0" />
                        </StackPanel>
                        <ScrollViewer MaxHeight="340" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding TypeFilters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked}" Margin="0,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Display}" />
                                                <TextBlock Text="{Binding Count, StringFormat=' ({0})'}"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Popup>
            <ui:TextBox x:Name="FilterBox" Icon="{ui:SymbolIcon Search24}"
                        PlaceholderText="Filter files by name"
                        Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>

        <!-- Main split: file list | preview -->
        <Grid Grid.Row="2" Margin="12,0,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="380" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="2*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="4">
                <ListView x:Name="FileList"
                          ItemsSource="{Binding Files}"
                          SelectedItem="{Binding SelectedFile}"
                          SelectionMode="Extended"
                          Background="Transparent" BorderThickness="0"
                          KeyDown="FileList_KeyDown"
                          MouseDoubleClick="FileList_MouseDoubleClick"
                          SizeChanged="FileList_SizeChanged"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.View>
                        <GridView>
                            <!-- Thumbnail (not sortable) -->
                            <GridViewColumn x:Name="IconColumn" Width="44">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="32" Height="32" CornerRadius="4"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                            <Image Source="{Binding Thumbnail}" Stretch="Uniform" Margin="2" />
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- Triage flag (not sortable) -->
                            <GridViewColumn x:Name="FlagColumn" Width="26">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="12" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Flag}" Value="Keep">
                                                            <Setter Property="Text" Value="✓" />
                                                            <Setter Property="Foreground" Value="#34C759" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Flag}" Value="Reject">
                                                            <Setter Property="Text" Value="✗" />
                                                            <Setter Property="Foreground" Value="#FF3B30" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn x:Name="NameColumn" Width="360">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader x:Name="HdrName" Content="Name" Tag="Name"
                                                          Click="ColumnHeader_Click" />
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontSize="14"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn x:Name="DateColumn" Width="140">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader x:Name="HdrDate" Content="Date modified" Tag="Date"
                                                          Click="ColumnHeader_Click" />
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ModifiedDisplay}" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn x:Name="TypeColumn" Width="80">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader x:Name="HdrType" Content="Type" Tag="Type"
                                                          Click="ColumnHeader_Click" />
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TypeDisplay}" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn x:Name="SizeColumn" Width="90">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader x:Name="HdrSize" Content="Size" Tag="Size"
                                                          Click="ColumnHeader_Click"
                                                          HorizontalContentAlignment="Right" />
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SizeDisplay}" FontSize="12"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" />

            <!-- Preview pane + quick-rename bar -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8">
                    <controls:PreviewPane x:Name="Preview" />
                </Border>

                <!-- Quick rename: type a name, Enter renames + advances to the next file -->
                <Border x:Name="QuickRenamePanel" Grid.Row="1" Margin="0,10,0,0" Padding="12"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8"
                        IsEnabled="False">
                    <StackPanel>
                        <TextBlock Text="QUICK RENAME" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6" />
                        <DockPanel LastChildFill="True">
                            <TextBlock x:Name="RenameExtLabel" DockPanel.Dock="Right" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="13" Margin="8,0,0,0" />
                            <ui:TextBox x:Name="RenameBox" FontSize="14"
                                        PlaceholderText="Name this file…"
                                        KeyDown="RenameBox_KeyDown"
                                        ToolTip="Type a name and press Enter — collisions auto-number (Clip, Clip 2, …). Esc returns to the list." />
                        </DockPanel>
                        <!-- Quick-use buttons (issue #14): one click drops a preset — or a live date —
                             into the box. Scrolls horizontally so any number of buttons fits; the "+"
                             on the far right adds a new one. Dynamic date buttons are styled apart. -->
                        <DockPanel Margin="0,8,0,0" LastChildFill="True">
                            <ToggleButton x:Name="AddButtonToggle" DockPanel.Dock="Right"
                                          Margin="6,0,0,0" Padding="8,4"
                                          ToolTip="Add a quick-use button">
                                <ui:SymbolIcon Symbol="Add24" FontSize="14" />
                            </ToggleButton>
                            <Popup PlacementTarget="{Binding ElementName=AddButtonToggle}" Placement="Top"
                                   StaysOpen="False" AllowsTransparency="True"
                                   IsOpen="{Binding IsChecked, ElementName=AddButtonToggle, Mode=TwoWay}">
                                <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:TextBox x:Name="NewButtonBox" Width="160" FontSize="13"
                                                    PlaceholderText="Button text…"
                                                    KeyDown="NewButtonBox_KeyDown" />
                                        <ui:Button Content="Add" Appearance="Primary" Margin="6,0,0,0"
                                                   Click="AddQuickButton_Click" />
                                    </StackPanel>
                                </Border>
                            </Popup>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <StackPanel Orientation="Horizontal">
                                    <!-- Dynamic buttons: distinct (accent) look — they insert a live date. -->
                                    <ui:Button x:Name="TodayButton" Appearance="Primary"
                                               Icon="{ui:SymbolIcon CalendarLtr24}"
                                               Click="TodayButton_Click"
                                               Margin="0,0,6,0" Padding="10,4" FontSize="12"
                                               ToolTip="Insert today's date (format set in Settings)" />
                                    <ui:Button x:Name="CreatedButton" Appearance="Primary"
                                               Icon="{ui:SymbolIcon CalendarClock24}"
                                               Click="CreatedButton_Click"
                                               Margin="0,0,6,0" Padding="10,4" FontSize="12"
                                               ToolTip="Insert the selected file's created date (format set in Settings)" />
                                    <!-- Static presets -->
                                    <ItemsControl ItemsSource="{Binding QuickNameButtons}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ui:Button Content="{Binding}" Click="QuickButton_Click"
                                                           Margin="0,0,6,0" Padding="10,4" FontSize="12"
                                                           ToolTip="Insert this text into the name" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>

                        <!-- Session name palette: recent names, click to re-apply (replaces the box). -->
                        <ItemsControl x:Name="Palette" ItemsSource="{Binding RecentNames}" Margin="0,8,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ui:Button Content="{Binding}" Click="PaletteChip_Click"
                                               Margin="0,0,6,6" Padding="10,4" FontSize="12"
                                               ToolTip="Stage this name — press Enter to apply" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <DockPanel Grid.Row="3" Margin="14,8,14,10">
            <TextBlock DockPanel.Dock="Right"
                       Text="Del = Recycle Bin · F2 = Rename · Enter = Open · K/X = Keep/Reject · U = Unmark"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="11" />
            <TextBlock Text="{Binding StatusText}" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </DockPanel>

        <!-- Triage overlay: covers everything below the title bar while swiping/reviewing -->
        <controls:TriageView x:Name="TriageOverlay" Grid.Row="1" Grid.RowSpan="3"
                             Visibility="Collapsed" />
    </Grid>
</ui:FluentWindow>

<Window x:Class="ExplorerHelper.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E24">
    <StackPanel Margin="16">
        <TextBlock Text="New name:" Foreground="#E8E8EC" Margin="0,0,0,6" />
        <TextBox x:Name="NameBox" Padding="6,4" FontSize="14"
                 Background="#2A2C34" Foreground="#E8E8EC" BorderBrush="#4A4C58" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" IsCancel="True" Padding="14,5" Margin="0,0,8,0"
                    Background="#33353F" Foreground="#E8E8EC" BorderBrush="#4A4C58" />
            <Button Content="Rename" IsDefault="True" Click="Ok_Click" Padding="14,5"
                    Background="#3D6EF7" Foreground="White" BorderBrush="#3D6EF7" />
        </StackPanel>
    </StackPanel>
</Window>

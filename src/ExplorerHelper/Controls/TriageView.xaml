<UserControl x:Class="ExplorerHelper.Controls.TriageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:ExplorerHelper.Controls"
             Background="{DynamicResource ApplicationBackgroundBrush}"
             Focusable="True"
             PreviewKeyDown="Root_PreviewKeyDown">
    <UserControl.Resources>
        <!-- Small thumbnail card used by both pile grids -->
        <DataTemplate x:Key="PileItemTemplate">
            <Border Width="132" Margin="4" Padding="6" CornerRadius="6"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    MouseLeftButtonDown="PileItem_MouseLeftButtonDown"
                    ToolTip="{Binding Name}">
                <StackPanel>
                    <Border Height="84" CornerRadius="4"
                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" Margin="2" />
                    </Border>
                    <TextBlock Text="{Binding Name}" FontSize="11" Margin="0,6,0,0"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding SizeDisplay}" FontSize="10"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <ui:Button Content="⇄" FontSize="11" Padding="7,2"
                                   Click="SwapPile_Click" ToolTip="Move to the other pile" />
                        <ui:Button Content="↩" FontSize="11" Padding="7,2" Margin="5,0,0,0"
                                   Click="UnflagItem_Click" ToolTip="Send back to the deck (unmark)" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <!-- ============================ DECK ============================ -->
        <Grid x:Name="DeckPanel">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top bar: progress, pile chips, review/exit -->
            <DockPanel Grid.Row="0" Margin="16,10" LastChildFill="True">
                <ui:Button DockPanel.Dock="Right" Content="Exit"
                           Click="Exit_Click"
                           ToolTip="Back to the list (Esc) — your marks are kept" />
                <ui:Button DockPanel.Dock="Right" Content="Review" Margin="0,0,8,0"
                           Icon="{ui:SymbolIcon ColumnDoubleCompare20}"
                           Click="Review_Click"
                           ToolTip="See both piles and commit" />
                <TextBlock x:Name="ProgressText" DockPanel.Dock="Left" FontSize="14"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <ui:Button Click="Review_Click" ToolTip="Rejected so far — click to review" Padding="10,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✗ " Foreground="#FF3B30" FontWeight="Bold" />
                            <TextBlock Text="{Binding RejectCount}" />
                        </StackPanel>
                    </ui:Button>
                    <TextBlock Text="{Binding UnmarkedFileCount, StringFormat='{}{0} left'}"
                               VerticalAlignment="Center" Margin="14,0" FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    <ui:Button Click="Review_Click" ToolTip="Kept so far — click to review" Padding="10,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✓ " Foreground="#34C759" FontWeight="Bold" />
                            <TextBlock Text="{Binding KeepCount}" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </DockPanel>

            <!-- Card area -->
            <Grid Grid.Row="1" Margin="24,4">
                <!-- Static peek at the next card, behind the live one (deliberately not a
                     second PreviewPane — one live video/PDF handle at a time is enough). -->
                <Border x:Name="NextCardHint" Margin="56,32,56,0" Opacity="0.12"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="12">
                    <Image x:Name="NextCardThumb" Width="96" Height="96" Stretch="Uniform"
                           Opacity="0.5"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <Border x:Name="Card" Margin="24,12"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="12"
                        RenderTransformOrigin="0.5,1"
                        MouseLeftButtonDown="Card_MouseLeftButtonDown"
                        MouseMove="Card_MouseMove"
                        MouseLeftButtonUp="Card_MouseLeftButtonUp">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <RotateTransform x:Name="CardRotate" />
                            <TranslateTransform x:Name="CardTranslate" />
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <controls:PreviewPane x:Name="CardPreview" Grid.Row="0" />

                        <Border Grid.Row="1" Padding="16,10"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,1,0,0">
                            <StackPanel MaxWidth="720" HorizontalAlignment="Center">
                                <TextBlock x:Name="CardName" FontSize="16" FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="CardDetail" FontSize="12" Margin="0,2,0,0"
                                           TextAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- Dating-app stamps: fade in as the card is dragged -->
                        <Border x:Name="KeepStamp" Grid.Row="0" Opacity="0" Margin="96,72,0,0"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                BorderBrush="#34C759" BorderThickness="6" CornerRadius="10"
                                Padding="22,8" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="KeepStampScale" />
                                    <RotateTransform Angle="-14" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <TextBlock Text="KEEP" Foreground="#34C759" FontSize="60" FontWeight="Bold" />
                        </Border>
                        <Border x:Name="RejectStamp" Grid.Row="0" Opacity="0" Margin="0,72,96,0"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                BorderBrush="#FF3B30" BorderThickness="6" CornerRadius="10"
                                Padding="22,8" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="RejectStampScale" />
                                    <RotateTransform Angle="14" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <TextBlock Text="REJECT" Foreground="#FF3B30" FontSize="60" FontWeight="Bold" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Shown when the deck runs out -->
                <StackPanel x:Name="DonePanel" Visibility="Collapsed"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="All caught up" FontSize="24" FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="DoneSummary" FontSize="13" Margin="0,8,0,18"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <ui:Button Content="Review &amp; commit" Appearance="Primary" Click="Review_Click" />
                        <ui:Button Content="Rewind" Click="Rewind_Click" Margin="8,0,0,0"
                                   ToolTip="Back up one card (Backspace)" />
                        <ui:Button Content="Exit" Click="Exit_Click" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Action buttons + hints -->
            <StackPanel x:Name="DeckButtons" Grid.Row="2" Margin="0,10,0,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <ui:Button Content="↶" Width="48" Height="48" CornerRadius="24" FontSize="18"
                               VerticalAlignment="Center" Click="Rewind_Click"
                               ToolTip="Rewind — back up one card and clear its mark (Backspace)" />
                    <ui:Button Content="✗" Width="68" Height="68" CornerRadius="34" FontSize="26"
                               Margin="20,0,0,0" Foreground="#FF3B30" FontWeight="Bold"
                               Click="Reject_Click" ToolTip="Reject (←) — recycled when you commit" />
                    <ui:Button Content="✓" Width="68" Height="68" CornerRadius="34" FontSize="26"
                               Margin="20,0,0,0" Foreground="#34C759" FontWeight="Bold"
                               Click="Keep_Click" ToolTip="Keep (→)" />
                    <ui:Button Content="⏭" Width="48" Height="48" CornerRadius="24" FontSize="18"
                               Margin="20,0,0,0" VerticalAlignment="Center" Click="Skip_Click"
                               ToolTip="Skip for now (↓) — decide later" />
                </StackPanel>
                <TextBlock Text="← reject · → keep · ↓ skip · Backspace rewind · Enter open · Esc exit"
                           HorizontalAlignment="Center" Margin="0,8,0,0" FontSize="11"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- ============================ REVIEW ============================ -->
        <Grid x:Name="ReviewPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="16,10">
                <ui:Button DockPanel.Dock="Right" Content="Exit" Click="Exit_Click"
                           ToolTip="Back to the list (Esc) — your marks are kept" />
                <ui:Button DockPanel.Dock="Right" Content="Back to deck" Margin="0,0,8,0"
                           Click="BackToDeck_Click" />
                <TextBlock Text="Review before commit" FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </DockPanel>

            <Border x:Name="UnmarkedStrip" Grid.Row="1" Margin="16,0,16,8" Padding="12,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <DockPanel>
                    <ui:Button DockPanel.Dock="Right" Content="Continue triage" Click="BackToDeck_Click" />
                    <TextBlock x:Name="UnmarkedText" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="2" Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="8">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="6,2,6,8">
                            <TextBlock Text="✓ Keep" Foreground="#34C759" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding KeepPileSummary}" Margin="8,0,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding KeepPile}"
                                          ItemTemplate="{StaticResource PileItemTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="8">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="6,2,6,8">
                            <TextBlock Text="✗ Reject" Foreground="#FF3B30" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding RejectPileSummary}" Margin="8,0,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding RejectPile}"
                                          ItemTemplate="{StaticResource PileItemTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <DockPanel Grid.Row="3" Margin="16,10,16,12">
                <ui:Button x:Name="CommitButton" DockPanel.Dock="Right" Appearance="Primary"
                           Content="Commit…" Click="Commit_Click" />
                <TextBlock Text="Nothing touches the disk until you commit — rejects go to the Recycle Bin, and one Ctrl+Z brings the whole commit back."
                           VerticalAlignment="Center" FontSize="11" TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>

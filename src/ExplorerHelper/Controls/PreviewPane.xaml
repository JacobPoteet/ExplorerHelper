<UserControl x:Class="ExplorerHelper.Controls.PreviewPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
    <Grid>
        <TextBlock x:Name="PreviewPlaceholder" Text="Select a file to preview it"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
        <Image x:Name="PreviewImage" Stretch="Uniform" Margin="8" Visibility="Collapsed" />
        <MediaElement x:Name="PreviewMedia" LoadedBehavior="Manual" Stretch="Uniform" Margin="8"
                      Visibility="Collapsed" ScrubbingEnabled="True"
                      MediaOpened="PreviewMedia_MediaOpened" MediaEnded="PreviewMedia_MediaEnded" />
        <wv2:WebView2 x:Name="PreviewWeb" Visibility="Collapsed" />
        <!-- Audio-only files have no video frame, so the media element renders
             nothing. Show a speaker so it's clear a file is selected and playing
             (issue #8). PreviewMedia keeps playing the audio underneath. -->
        <StackPanel x:Name="PreviewAudio" Visibility="Collapsed"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <Viewbox Width="132" Height="132" HorizontalAlignment="Center">
                <Canvas Width="24" Height="24">
                    <Path Fill="{DynamicResource AccentFillColorDefaultBrush}"
                          Data="M3,9 L6,9 L10.5,5 L10.5,19 L6,15 L3,15 Z" />
                    <Path Stroke="{DynamicResource AccentFillColorDefaultBrush}" StrokeThickness="1.6"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="M13.5,8.5 C15.3,10.5 15.3,13.5 13.5,15.5" />
                    <Path Stroke="{DynamicResource AccentFillColorDefaultBrush}" StrokeThickness="1.6"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="M16,6 C19.5,9 19.5,15 16,18" />
                </Canvas>
            </Viewbox>
            <TextBlock x:Name="PreviewAudioName" FontSize="15" Margin="0,14,0,2"
                       HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"
                       MaxWidth="320" />
            <TextBlock x:Name="PreviewAudioDetail" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>
        <StackPanel x:Name="PreviewInfo" Visibility="Collapsed"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image x:Name="PreviewInfoThumb" Width="128" Height="128" Stretch="Uniform" />
            <TextBlock x:Name="PreviewInfoName" FontSize="15" Margin="0,12,0,2"
                       HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="320" />
            <TextBlock x:Name="PreviewInfoDetail" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Video scrubbing timeline (issue #19): play/pause, elapsed/total time, and a draggable
             slider to jump anywhere in the clip. Overlays the bottom of the video; shown only while
             a video is previewing. -->
        <Border x:Name="VideoControls" Visibility="Collapsed"
                VerticalAlignment="Bottom" Margin="12" Padding="10,6"
                Background="#C0202020" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button x:Name="PlayPauseButton" Grid.Column="0" Content="⏸"
                        Width="30" Height="30" FontSize="13" Padding="0"
                        Background="Transparent" BorderThickness="0" Foreground="White"
                        Cursor="Hand" Click="PlayPauseButton_Click"
                        ToolTip="Play / pause" />
                <TextBlock x:Name="PositionText" Grid.Column="1" Text="0:00"
                           Foreground="White" FontSize="12" VerticalAlignment="Center"
                           Margin="6,0,8,0" />
                <Slider x:Name="TimelineSlider" Grid.Column="2" VerticalAlignment="Center"
                        Minimum="0" Maximum="1" SmallChange="1" LargeChange="5"
                        IsMoveToPointEnabled="True"
                        ValueChanged="TimelineSlider_ValueChanged" />
                <TextBlock x:Name="DurationText" Grid.Column="3" Text="0:00"
                           Foreground="White" FontSize="12" VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </Grid>
        </Border>
    </Grid>
</UserControl>

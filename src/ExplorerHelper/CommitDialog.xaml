<ui:FluentWindow x:Class="ExplorerHelper.CommitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Commit triage" Width="500" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <StackPanel>
        <ui:TitleBar Title="Commit triage" ShowMinimize="False" ShowMaximize="False" />
        <StackPanel Margin="16,4,16,16">
            <!-- Rejects card -->
            <Border Padding="12,10" CornerRadius="8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="RejectLine" FontSize="14"
                               Foreground="{StaticResource RejectBrush}" FontWeight="SemiBold" />
                    <StackPanel x:Name="DeletePanel" Margin="0,8,0,0">
                        <CheckBox x:Name="DeleteRejectsCheck"
                                  Content="Send rejected files to the Recycle Bin"
                                  IsChecked="True" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Keeps card -->
            <Border Padding="12,10" CornerRadius="8" Margin="0,10,0,0"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="KeepLine" FontSize="14"
                               Foreground="{StaticResource KeepBrush}" FontWeight="SemiBold" />
                    <StackPanel x:Name="MovePanel" Margin="0,8,0,0">
                        <CheckBox x:Name="MoveCheck" Content="Move or copy kept files to a folder"
                                  Checked="MoveCheck_Changed" Unchecked="MoveCheck_Changed" />
                        <StackPanel Orientation="Horizontal" Margin="30,6,0,0">
                            <RadioButton x:Name="MoveRadio" Content="Move" GroupName="MoveOrCopy"
                                         IsChecked="True" IsEnabled="False" />
                            <RadioButton x:Name="CopyRadio" Content="Copy" GroupName="MoveOrCopy"
                                         Margin="16,0,0,0" IsEnabled="False" />
                        </StackPanel>
                        <DockPanel Margin="30,8,0,0">
                            <ui:Button x:Name="BrowseButton" DockPanel.Dock="Right" Content="Browse…"
                                       Click="Browse_Click" Margin="8,0,0,0" IsEnabled="False" />
                            <ui:TextBox x:Name="DestBox" FontSize="13" IsEnabled="False"
                                        PlaceholderText="Destination folder…" />
                        </DockPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="One Ctrl+Z afterwards reverses the whole commit."
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="11" Margin="0,12,0,0" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <ui:Button Content="Cancel" IsCancel="True" Margin="0,0,8,0" />
                <ui:Button Content="Commit" Appearance="Primary" IsDefault="True" Click="Ok_Click" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</ui:FluentWindow>

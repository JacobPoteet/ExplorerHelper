<Window x:Class="ExplorerHelper.CommitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Commit triage" Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E24">
    <StackPanel Margin="16">
        <TextBlock x:Name="RejectLine" Foreground="#E8E8EC" FontSize="14" />
        <StackPanel x:Name="DeletePanel" Margin="0,6,0,0">
            <CheckBox x:Name="DeleteRejectsCheck" Content="Send rejected files to the Recycle Bin"
                      Foreground="#E8E8EC" IsChecked="True" />
        </StackPanel>
        <TextBlock x:Name="KeepLine" Foreground="#E8E8EC" FontSize="14" Margin="0,14,0,0" />

        <StackPanel x:Name="MovePanel" Margin="0,14,0,0">
            <CheckBox x:Name="MoveCheck" Content="Move or copy kept files to a folder"
                      Foreground="#E8E8EC"
                      Checked="MoveCheck_Changed" Unchecked="MoveCheck_Changed" />
            <StackPanel Orientation="Horizontal" Margin="22,8,0,0">
                <RadioButton x:Name="MoveRadio" Content="Move" GroupName="MoveOrCopy"
                             Foreground="#E8E8EC" IsChecked="True" IsEnabled="False" />
                <RadioButton x:Name="CopyRadio" Content="Copy" GroupName="MoveOrCopy"
                             Foreground="#E8E8EC" Margin="16,0,0,0" IsEnabled="False" />
            </StackPanel>
            <DockPanel Margin="22,8,0,0">
                <Button x:Name="BrowseButton" DockPanel.Dock="Right" Content="Browse…"
                        Click="Browse_Click" Padding="12,4" Margin="8,0,0,0" IsEnabled="False"
                        Background="#33353F" Foreground="#E8E8EC" BorderBrush="#4A4C58" />
                <TextBox x:Name="DestBox" Padding="6,4" FontSize="13" IsEnabled="False"
                         Background="#2A2C34" Foreground="#E8E8EC" BorderBrush="#4A4C58" />
            </DockPanel>
        </StackPanel>

        <TextBlock Text="One Ctrl+Z afterwards reverses the whole commit."
                   Foreground="#9A9AA6" FontSize="11" Margin="0,14,0,0" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" IsCancel="True" Padding="14,5" Margin="0,0,8,0"
                    Background="#33353F" Foreground="#E8E8EC" BorderBrush="#4A4C58" />
            <Button Content="Commit" IsDefault="True" Click="Ok_Click" Padding="14,5"
                    Background="#3D6EF7" Foreground="White" BorderBrush="#3D6EF7" />
        </StackPanel>
    </StackPanel>
</Window>

<?xml version="1.0" encoding="utf-8"?>
<!--
  Sparse MSIX manifest for Explorer Helper's Windows 11 top-level context menu (issue #11).

  "Sparse" means the signed .msix carries only this manifest plus the logos under Images\; the
  real payload (ExplorerHelper.exe and the shell-extension COM host DLL) lives in an external
  location on disk and is referenced via uap10:AllowExternalContent. Build and install it with
  packaging\Build-SparsePackage.ps1.

  The Publisher below must exactly match the subject of the certificate used to sign the package.
  The Clsid must match ExplorerHelper.ShellExtension.ExplorerHelperCommand's [Guid].
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  xmlns:desktop4="http://schemas.microsoft.com/appx/manifest/desktop/windows10/4"
  xmlns:desktop5="http://schemas.microsoft.com/appx/manifest/desktop/windows10/5"
  IgnorableNamespaces="uap uap10 rescap com desktop4 desktop5">

  <Identity Name="JacobPoteet.ExplorerHelper"
            Publisher="CN=Explorer Helper Dev"
            Version="0.1.0.0"
            ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Explorer Helper</DisplayName>
    <PublisherDisplayName>Jacob Poteet</PublisherDisplayName>
    <Logo>Images\StoreLogo.png</Logo>
    <!-- The package payload is delivered from an external folder, not bundled in the .msix. -->
    <uap10:AllowExternalContent>true</uap10:AllowExternalContent>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="ExplorerHelper"
                 Executable="ExplorerHelper.exe"
                 uap10:RuntimeBehavior="win32App"
                 uap10:TrustLevel="mediumIL">
      <uap:VisualElements
          DisplayName="Explorer Helper"
          Description="Clean and organize folders straight from the Explorer context menu."
          BackgroundColor="transparent"
          Square150x150Logo="Images\Square150x150Logo.png"
          Square44x44Logo="Images\Square44x44Logo.png"
          AppListEntry="none" />
      <Extensions>
        <!-- Register the shell-extension COM class, hosted out-of-proc by the shell surrogate. -->
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com:SurrogateServer DisplayName="Explorer Helper context menu">
              <com:Class Id="21E1DA0A-3D1D-4678-B6F5-60FFE2D6C26B"
                         Path="ExplorerHelper.ShellExtension.comhost.dll"
                         ThreadingModel="STA" />
            </com:SurrogateServer>
          </com:ComServer>
        </com:Extension>
        <!-- Attach the command to the Win11 top-level menu for folders and folder backgrounds. -->
        <desktop4:Extension Category="windows.fileExplorerContextMenus">
          <desktop4:FileExplorerContextMenus>
            <desktop5:ItemType Type="Directory">
              <desktop5:Verb Id="CleanFolder" Clsid="21E1DA0A-3D1D-4678-B6F5-60FFE2D6C26B" />
            </desktop5:ItemType>
            <desktop5:ItemType Type="Directory\Background">
              <desktop5:Verb Id="CleanFolder" Clsid="21E1DA0A-3D1D-4678-B6F5-60FFE2D6C26B" />
            </desktop5:ItemType>
          </desktop4:FileExplorerContextMenus>
        </desktop4:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
